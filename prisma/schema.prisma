generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  passwordHash   String
  role           UserRole
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchases      Purchase[]
  cancelledSales Sale[]          @relation("SaleCancelledBy")
  sales          Sale[]
  stockMoves     StockMovement[]
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id            String              @id @default(cuid())
  name          String
  description   String?
  status        ProductStatus       @default(ACTIVO)
  categoryId    String?
  stock         Decimal             @db.Decimal(10, 3)
  stockMin      Decimal             @default(0) @db.Decimal(10, 3)
  isPerishable  Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  saleFormats   ProductSaleFormat[]
  category      Category?           @relation(fields: [categoryId], references: [id])
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  stockMoves    StockMovement[]

  @@index([name])
  @@index([status])
  @@map("products")
}

model ProductSaleFormat {
  id          String      @id @default(cuid())
  productId   String
  unitMeasure UnitMeasure
  label       String?
  price       Decimal     @db.Decimal(10, 2)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  saleItems   SaleItem[]

  @@unique([productId, unitMeasure])
  @@index([productId])
  @@map("product_sale_formats")
}

model Supplier {
  id        String     @id @default(cuid())
  name      String
  phone     String?
  address   String?
  email     String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@index([name])
  @@map("suppliers")
}

model Sale {
  id                 String          @id @default(cuid())
  saleNumber         Int             @unique @default(autoincrement())
  status             SaleStatus      @default(COMPLETADA)
  userId             String
  subtotal           Decimal         @db.Decimal(12, 2)
  discount           Decimal         @default(0) @db.Decimal(12, 2)
  total              Decimal         @db.Decimal(12, 2)
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  cashReceived       Decimal?        @db.Decimal(12, 2)
  changeGiven        Decimal?        @db.Decimal(12, 2)
  paymentMethod      PaymentMethod
  items              SaleItem[]
  cancelledBy        User?           @relation("SaleCancelledBy", fields: [cancelledById], references: [id])
  user               User            @relation(fields: [userId], references: [id])
  stockMoves         StockMovement[]

  @@index([createdAt])
  @@index([status])
  @@map("sales")
}

model SaleItem {
  id                  String             @id @default(cuid())
  saleId              String
  productId           String
  productSaleFormatId String?
  productNameSnapshot String
  formatLabelSnapshot String?
  unitMeasure         UnitMeasure
  quantity            Decimal            @db.Decimal(10, 3)
  unitPrice           Decimal            @db.Decimal(10, 2)
  subtotal            Decimal            @db.Decimal(12, 2)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  product             Product            @relation(fields: [productId], references: [id])
  productSaleFormat   ProductSaleFormat? @relation(fields: [productSaleFormatId], references: [id])
  sale                Sale               @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Purchase {
  id             String          @id @default(cuid())
  purchaseNumber Int             @unique @default(autoincrement())
  status         PurchaseStatus  @default(REGISTRADA)
  supplierId     String
  userId         String?
  subtotal       Decimal         @db.Decimal(12, 2)
  total          Decimal         @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  items          PurchaseItem[]
  supplier       Supplier        @relation(fields: [supplierId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  stockMoves     StockMovement[]

  @@index([createdAt])
  @@index([status])
  @@map("purchases")
}

model PurchaseItem {
  id                  String      @id @default(cuid())
  purchaseId          String
  productId           String
  productNameSnapshot String
  unitMeasure         UnitMeasure
  quantity            Decimal     @db.Decimal(10, 3)
  unitCost            Decimal     @db.Decimal(10, 2)
  subtotal            Decimal     @db.Decimal(12, 2)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  product             Product     @relation(fields: [productId], references: [id])
  purchase            Purchase    @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model StockMovement {
  id            String            @id @default(cuid())
  productId     String
  type          StockMovementType
  quantity      Decimal           @db.Decimal(10, 3)
  previousStock Decimal           @db.Decimal(10, 3)
  newStock      Decimal           @db.Decimal(10, 3)
  saleId        String?
  purchaseId    String?
  userId        String?
  reason        String?
  createdAt     DateTime          @default(now())
  product       Product           @relation(fields: [productId], references: [id])
  purchase      Purchase?         @relation(fields: [purchaseId], references: [id])
  sale          Sale?             @relation(fields: [saleId], references: [id])
  user          User?             @relation(fields: [userId], references: [id])

  @@index([productId, createdAt])
  @@index([type])
  @@index([saleId])
  @@index([purchaseId])
  @@map("stock_movements")
}

enum UserRole {
  ADMIN
  CAJERO
}

enum ProductStatus {
  ACTIVO
  INACTIVO
}

enum SaleStatus {
  COMPLETADA
  CANCELADA
}

enum PurchaseStatus {
  REGISTRADA
  CANCELADA
}

enum StockMovementType {
  ENTRADA_COMPRA
  SALIDA_VENTA
  AJUSTE_MANUAL
  REVERSO_VENTA
  REVERSO_COMPRA
}

enum UnitMeasure {
  UNIDAD
  DOCENA
  MEDIA_DOCENA
  KILOGRAMO
  PORCION
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
}
